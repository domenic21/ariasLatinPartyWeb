# ============================================================
# ENVIRONMENT VARIABLES (template)
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real keys.
# For production, set these same vars in the Vercel dashboard:
#   Project → Settings → Environment Variables
# ============================================================

# ---- Resend (server-side email — used by /api/booking) ----
# Your Resend secret API key (starts with "re_"). Keep secret.
RESEND_API_KEY=

# Where booking/date requests are delivered.
BOOKING_TO_EMAIL=darias@vcssoftware.com

# The "From" address. Must be a verified domain in Resend.
# For quick testing you can use: Arias Latin Party <onboarding@resend.dev>
# (that only delivers to your own Resend account email).
# In production, verify ariaslatinparty.com in Resend and use e.g.:
#   Arias Latin Party <bookings@ariaslatinparty.com>
BOOKING_FROM_EMAIL=Arias Latin Party <onboarding@resend.dev>

# ---- Cloudflare Turnstile (invisible CAPTCHA / anti-spam) ----
# Free keys: https://dash.cloudflare.com → Turnstile → add a site.
# The site key is public (shipped to the browser); the secret stays server-side.
# Leave both blank to disable the CAPTCHA (forms still work).
# Local testing "always pass" keys:
#   PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- EmailJS (client-side — currently unused; kept for reference) ----
PUBLIC_EMAILJS_SERVICE_ID=
PUBLIC_EMAILJS_TEMPLATE_ID=
PUBLIC_EMAILJS_PUBLIC_KEY=
