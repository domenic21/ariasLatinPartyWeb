---
/* ============================================================
   LINKTREE PAGE  (/linktree)
   ------------------------------------------------------------
   A bio-link page (like Linktree) for your Instagram/TikTok bio.
   Reuses the site's dark/neon theme + the same Layout for SEO.
   Content comes from: src/data/site.ts -> `linktree`
   Ported & restyled from your original linktree.tsx.
   ============================================================ */
import Layout from "../layouts/Layout.astro";
import { getContent, shared } from "../data/site";
const { linktree } = getContent(Astro.currentLocale);
---

<Layout
  title={`${shared.linktreeName} — ${linktree.subtitle}`}
  description={linktree.tagline}
>
  <main class="relative flex min-h-screen items-center justify-center overflow-hidden px-6 py-12">
    {/* Faint logo watermark in the background, matching the homepage hero */}
    <img
      src="/images/logo.png"
      alt=""
      aria-hidden="true"
      class="pointer-events-none absolute left-1/2 top-1/2 -z-10 w-[90%] max-w-[500px] -translate-x-1/2 -translate-y-1/2 opacity-[0.06] blur-[1px]"
    />

    {/* The bio card */}
    <div
      class="w-full max-w-sm rounded-3xl border border-white/10 bg-ink-soft/80 p-6 text-center backdrop-blur-md sm:max-w-md sm:p-8"
    >
      {/* Logo (object-contain so it isn't cropped like a face photo) */}
      <img
        src={shared.linktreeAvatar}
        alt={linktree.subtitle}
        class="mx-auto mb-5 h-28 w-28 object-contain"
      />

      <h1 class="font-display text-3xl font-black italic">
        {shared.linktreeName}
      </h1>
      <p class="mt-1 text-sm font-semibold tracking-widest text-neon-blue">
        {linktree.subtitle.toUpperCase()}
      </p>
      <p class="mt-3 text-sm text-white/60">{linktree.tagline}</p>

      {/* The links — maps over linktree.links */}
      <div class="mt-8 flex flex-col gap-3">
        {
          linktree.links.map((link) => (
            <a
              href={link.url}
              target={link.url.startsWith("http") ? "_blank" : undefined}
              rel={link.url.startsWith("http") ? "noopener noreferrer" : undefined}
              class={`block w-full break-words rounded-full px-5 py-3.5 text-sm font-semibold transition-all duration-300 hover:opacity-90 ${link.style}`}
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </main>
</Layout>
