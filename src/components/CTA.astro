---
/* ============================================================
   CTA  (final "READY FOR THE IMPACT?" booking block)
   Content comes from: src/data/site.ts -> `cta`
   ============================================================ */
import { getContent } from "../data/site";
import BookingForm from "./BookingForm.jsx";
import ContactModal from "./ContactModal.jsx";
const lang = Astro.currentLocale ?? "en";
const { cta, booking, contact } = getContent(lang);
---

<section id="contact" class="mx-auto max-w-5xl px-6 py-28">
  <div
    class="rounded-3xl border border-white/10 bg-ink-soft p-12 text-center sm:p-16"
  >
    <h2 class="font-display text-5xl font-black italic sm:text-6xl">
      <span class="block">{cta.titleLines[0]}</span>
      <span class="block text-gradient">{cta.titleLines[1]}</span>
    </h2>

    <p class="mx-auto mt-5 max-w-md text-sm text-white/60">{cta.body}</p>

    {/* Phone numbers + service area */}
    <div
      class="mt-10 flex flex-wrap items-center justify-center gap-x-12 gap-y-6 text-left"
    >
      <div>
        <div class="text-xs tracking-widest text-white/40">{cta.labels.access}</div>
        {cta.phones.map((p) => <div class="font-display text-xl font-bold">{p}</div>)}
      </div>
      <div>
        <div class="text-xs tracking-widest text-white/40">{cta.labels.hq}</div>
        <div class="font-display text-xl font-bold">{cta.serviceArea}</div>
      </div>
    </div>

    <ContactModal
      client:visible
      triggerLabel={cta.button.label}
      booking={booking}
      contact={contact}
    />
  </div>

  {/* ---- Date-request calendar + form (emails via /api/booking) ---- */}
  <div class="mt-12 text-center">
    <div class="text-xs tracking-widest text-white/40">{booking.eyebrow}</div>
    <h3 class="mt-2 font-display text-3xl font-black italic sm:text-4xl">
      {booking.title}
    </h3>
    <p class="mx-auto mt-3 max-w-xl text-sm text-white/60">{booking.intro}</p>
  </div>

  <div class="mt-8">
    <BookingForm client:visible labels={booking} lang={lang} />
  </div>
</section>
