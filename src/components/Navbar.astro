---
/* ============================================================
   NAVBAR  (top navigation bar)
   Content comes from: src/data/site.ts -> `nav`
   ============================================================ */
import { getContent } from "../data/site";
const t = getContent(Astro.currentLocale);
const { nav, ui } = t;
---

<header
  class="fixed top-0 left-0 z-50 w-full border-b border-white/5 bg-ink/70 backdrop-blur-md"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    {/* Brand / logo (text) */}
    <a href="#top" class="font-display text-lg font-extrabold tracking-tight">
      {nav.brand}
    </a>

    {/* Center links — hidden on small screens */}
    <ul class="hidden items-center gap-8 md:flex">
      {
        nav.links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm text-white/70 transition hover:text-white"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      {/* Language switch — links to the other language's homepage.
          ui.langLabel / ui.langHref come from src/data/site.ts. */}
      <a
        href={ui.langHref}
        class="rounded-full border border-white/20 px-3 py-2 text-xs font-semibold text-white/80 transition hover:bg-white/10"
        aria-label="Change language"
      >
        {ui.langLabel}
      </a>

      {/* Call-to-action button */}
      <a
        href={nav.cta.href}
        class="rounded-full bg-neon-blue px-5 py-2 text-sm font-semibold text-ink transition hover:opacity-90"
      >
        {nav.cta.label}
      </a>
    </div>
  </nav>
</header>
