---
/* ============================================================
   SERVICES  ("GEAR & ENERGY" / specializations grid)
   Content comes from: src/data/site.ts -> `services`
   ============================================================ */
import { getContent } from "../data/site";
import ModelViewer from "./three/ModelViewer.jsx";
const { services } = getContent(Astro.currentLocale);
---

<section id="services" class="mx-auto max-w-7xl px-6 py-28">
  {/* Section heading */}
  <p class="text-sm font-semibold tracking-[0.3em] text-white/40">
    {services.eyebrow}
  </p>
  <div class="mt-2 flex flex-wrap items-end justify-between gap-4">
    <h2 class="font-display text-5xl font-black italic sm:text-6xl">
      {services.title}
    </h2>
    <p class="max-w-sm text-sm text-white/60">{services.intro}</p>
  </div>

  {/* ---- FLOATING 3D SPEAKER (KRK CE-99) ----
       client:only="react" => browser-only (Three.js/WebGL).
       Reuses the generic ModelViewer. Height is responsive so it
       stays reasonable on phones. The animate-float class makes it
       gently bob like the hero console. */}
  <div class="animate-float mt-12 h-[280px] w-full sm:h-[360px]">
    <ModelViewer
      client:only="react"
      src="/models/krk_ce_99/scene.gltf"
      cameraPosition={[1.5, 0.3, 4]}
      fov={35}
      boundsMargin={0.5}
      hideMaterials={["Noir_tube"]}
      oscillate={true}
    />
  </div>

  {/* Cards grid — maps over services.cards */}
  <div class="mt-4 grid gap-5 md:grid-cols-2">
    {
      services.cards.map((card) => (
        <article class="rounded-2xl border border-white/10 bg-ink-soft p-8 transition hover:border-neon-blue/40">
          <h3 class="font-display text-2xl font-bold">{card.title}</h3>
          <p class="mt-3 text-sm text-white/60">{card.body}</p>

          {/* Optional genre tags (only some cards have them) */}
          {card.tags && card.tags.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-2">
              {card.tags.map((tag) => (
                <span class="rounded-full border border-white/15 px-3 py-1 text-xs text-white/70">
                  {tag}
                </span>
              ))}
            </div>
          )}

          {/* Optional stats (e.g. Hora Loca: MAX energy / 4K LED) */}
          {card.stats && (
            <div class="mt-6 flex gap-8">
              {card.stats.map((stat) => (
                <div>
                  <div class="font-display text-3xl font-black text-neon-blue">
                    {stat.value}
                  </div>
                  <div class="text-xs tracking-widest text-white/40">
                    {stat.label}
                  </div>
                </div>
              ))}
            </div>
          )}
        </article>
      ))
    }
  </div>
</section>
