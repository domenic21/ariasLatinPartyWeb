---
/* ============================================================
   FAQ  (visible questions & answers)
   ------------------------------------------------------------
   Important for AI-search (AEO): AI engines and Google reward
   sites where the visible text MATCHES the FAQ structured data
   in Layout.astro. Both read from the SAME source:
   src/data/site.ts -> `seo.faq`  (edit there to change both).
   Uses native <details> so answers expand with zero JavaScript.
   ============================================================ */
import { getContent } from "../data/site";
const { seo, ui } = getContent(Astro.currentLocale);
---

<section class="mx-auto max-w-3xl px-6 py-24">
  <h2 class="text-center font-display text-4xl font-black italic sm:text-5xl">
    {ui.faqHeading}
  </h2>

  <div class="mt-12 space-y-3">
    {
      seo.faq.map((item) => (
        <details class="group rounded-2xl border border-white/10 bg-ink-soft p-5">
          <summary class="flex cursor-pointer items-center justify-between text-base font-semibold">
            {item.q}
            <span class="ml-4 text-neon-blue transition group-open:rotate-45">
              +
            </span>
          </summary>
          <p class="mt-3 text-sm text-white/60">{item.a}</p>
        </details>
      ))
    }
  </div>
</section>
