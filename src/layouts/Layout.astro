---
/* ============================================================
   BASE LAYOUT  (+ all SEO and AI-search optimization)
   ------------------------------------------------------------
   Wraps every page. The <head> here contains:
     1. Standard SEO meta (title, description, canonical)
     2. Open Graph + Twitter cards (rich social/chat previews)
     3. JSON-LD structured data (how Google AND AI engines —
        ChatGPT, Perplexity, AI Overviews — understand the site)
   All values come from src/data/site.ts -> `seo`.
   ============================================================ */
import "../styles/global.css";
import { getContent, shared } from "../data/site";

// Pick language from the URL (Astro.currentLocale). Fall back to English.
const lang = Astro.currentLocale ?? "en";
const { seo } = getContent(lang);

interface Props {
  title?: string;
  description?: string;
}
const { title = seo.title, description = seo.description } = Astro.props;

// Build absolute URLs (required by Open Graph + canonical).
// Astro.site comes from `site:` in astro.config.mjs.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(shared.ogImage, Astro.site);

/* ---- STRUCTURED DATA (JSON-LD) ----
   Three schemas, combined into one @graph:
   - LocalBusiness: tells engines this is a real, locatable service.
   - Person: establishes Edison Arias as the founder/expert (E-E-A-T).
   - FAQPage: lets Google + AI engines pull direct Q&A answers.
   This is the single biggest lever for AI-engine visibility. */
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["LocalBusiness", "MusicGroup"],
      "@id": `${Astro.site}#business`,
      name: shared.business.name,
      description: seo.description,
      url: Astro.site?.toString(),
      telephone: shared.business.phone,
      email: shared.business.email,
      image: ogImageURL.toString(),
      priceRange: shared.business.priceRange,
      areaServed: shared.business.areaServed,
      founder: { "@id": `${Astro.site}#founder` },
      sameAs: shared.business.sameAs,
    },
    {
      "@type": "Person",
      "@id": `${Astro.site}#founder`,
      name: shared.business.founderName,
      jobTitle: "DJ & Sound Engineer",
      worksFor: { "@id": `${Astro.site}#business` },
      knowsAbout: [
        "Latin Music",
        "DJ Performance",
        "Live Sound Engineering",
        "Hora Loca Productions",
      ],
    },
    {
      "@type": "FAQPage",
      "@id": `${Astro.site}#faq`,
      mainEntity: seo.faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* ---- Primary SEO meta ---- */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={seo.keywords} />
    <meta name="author" content={shared.business.founderName} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    {/* ---- Open Graph (Facebook, LinkedIn, iMessage, WhatsApp, etc.) ---- */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={shared.business.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />

    {/* ---- Twitter / X card ---- */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {/* ---- Structured data for Google + AI engines ---- */}
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />

    {/* Fonts: Archivo (headings) + Inter (body) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400..900;1,700&family=Inter:wght@400;500;600&family=Nosifer&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {/* Ecuador-flag scroll progress bar (fills as you scroll down) */}
    <div id="scroll-progress"></div>

    <slot />

    {/* ---- Floating WhatsApp button (all pages) ---- */}
    <a
      href="https://wa.me/12015544914"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={lang === "es" ? "Escríbenos por WhatsApp" : "Message us on WhatsApp"}
      class="fixed bottom-5 right-5 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] shadow-lg shadow-black/30 transition hover:scale-105 hover:bg-[#1ebe5b]"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="white"
        class="h-7 w-7"
        aria-hidden="true"
      >
        <path
          d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.82 9.82 0 0 0 1.523 5.26l-.999 3.648 3.965-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
        ></path>
      </svg>
    </a>

    <script is:inline>
      // Update the progress bar width based on how far the page is scrolled.
      (function () {
        const bar = document.getElementById("scroll-progress");
        function update() {
          const h = document.documentElement;
          const scrolled = h.scrollTop;
          const max = h.scrollHeight - h.clientHeight;
          bar.style.width = (max > 0 ? (scrolled / max) * 100 : 0) + "%";
        }
        window.addEventListener("scroll", update, { passive: true });
        window.addEventListener("resize", update);
        update();
      })();
    </script>
  </body>
</html>
